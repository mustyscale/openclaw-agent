# ─────────────────────────────────────────
#  OpenClaw Agent — Environment Variables
#  Copy to .env and fill in per client
# ─────────────────────────────────────────

# CLIENT IDENTITY
CLIENT_NAME=Brand Name
CLIENT_ID=brandname          # used in logs and PM2 process name

# ── AI ────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── STORE PLATFORM (pick one) ─────────────

# Shopify
SHOPIFY_STORE_URL=yourstore.myshopify.com
SHOPIFY_ACCESS_TOKEN=shpat_...

# WooCommerce
WOOCOMMERCE_URL=https://yourstore.com
WOOCOMMERCE_CONSUMER_KEY=ck_...
WOOCOMMERCE_CONSUMER_SECRET=cs_...

# ── OPTIONAL INTEGRATIONS ─────────────────
KLAVIYO_API_KEY=pk_...
GORGIAS_API_KEY=
GORGIAS_BASE_URL=https://yourstore.gorgias.com

# ── DELIVERY (enable one or more) ─────────

# WhatsApp via Twilio
WHATSAPP_ENABLED=true
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
WHATSAPP_TO=whatsapp:+1234567890   # client's number

# Telegram
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=...
TELEGRAM_CHAT_ID=...

# Slack
SLACK_ENABLED=false
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...

# ── AUTOMATION SETTINGS ───────────────────

# Daily briefing
BRIEFING_HOUR=8               # 8 = 8:00 AM
BRIEFING_MINUTE=0
TIMEZONE=Europe/Istanbul      # client's local timezone

# Order scan
ORDER_SCAN_ENABLED=true
ORDER_SCAN_INTERVAL_MIN=30    # every 30 minutes
HIGH_VALUE_ORDER_THRESHOLD=500

# Stock monitor
STOCK_MONITOR_ENABLED=true
STOCK_MONITOR_INTERVAL_MIN=60
LOW_STOCK_THRESHOLD=20        # alert when units drop below this

# Refund monitor
REFUND_MONITOR_ENABLED=true
REFUND_MONITOR_INTERVAL_MIN=60
REFUND_SPIKE_COUNT=5          # alert if X refunds in the window
REFUND_SPIKE_WINDOW_HOURS=2
